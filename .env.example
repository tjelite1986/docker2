# =============================================================================
# Globala variabler – kopieras till .env
# =============================================================================
PUID=1000
PGID=1000
TZ=Europe/Stockholm
DOMAIN=yourdomain.com
NETWORKS=traefik
DOCKERDIR=/home/youruser/docker2
DATADIR=/home/youruser/dockdata

# Traefik – Cloudflare DNS-challenge
CF_API_EMAIL=your-cloudflare-email@example.com
CF_DNS_API_TOKEN=your-cloudflare-api-token
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=hashed-password-here
