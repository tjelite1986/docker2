# MCP-server autentisering
# Generera med: docker run --rm httpd:alpine htpasswd -nb användare lösenord
# Exempel: MCP_BASIC_AUTH=thomas:$$apr1$$xyz...
# OBS: Dubbla $ i .env-filen ($$) för att escapa Compose-variabelsubstitution
MCP_BASIC_AUTH=thomas:GENERATE_WITH_HTPASSWD

# Globala variabler (ärvs från rot-.env)
# DOMAIN=mecloud.win
